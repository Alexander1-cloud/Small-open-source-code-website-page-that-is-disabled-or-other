<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /
    RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
    RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
</IfModule>
<FilesMatch "\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>
<FilesMatch "^index\.php$">
    Allow from all
</FilesMatch>