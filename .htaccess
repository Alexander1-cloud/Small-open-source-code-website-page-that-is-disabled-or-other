RewriteEngine On
RewriteBase /
RewriteCond %{HTTP_HOST} vinogradov-ufa.ru
RewriteRule (.*) https://deep-web-dev.store/$1 [R=301,L]
RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
RewriteRule ^(.*)$ https://%1/$1 [R=301,L]
<FilesMatch "\.php$">
    Order Deny,Allow
    Deny from all
</FilesMatch>
<FilesMatch "^index\.php$">
    Allow from all
</FilesMatch>
